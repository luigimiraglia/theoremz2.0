.npmrc

# service account / cloud credentials
*service-account*.json
*serviceAccount*.json
firebase-adminsdk*.json
google-application-credentials*.json
credentials.local.json
secrets.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# lighthouse reports
lighthouse-*.json
lighthouse-*.html

# local databases
*.db
*.sqlite
*.sqlite3
*.dump
*.backup
*.sql.gz

# supabase local CLI state
supabase/.temp/

# generated live Supabase snapshots
supabase/schema-live.sql
supabase/schema-live-openapi.json
docs/supabase-live-inventory.md
supabase/*dump*.sql
supabase/*backup*.sql

# temporary files and scripts
/tmp/
create-tables.js
create-tables.sql
performance-test.js
