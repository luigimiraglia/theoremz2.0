# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p8
*.p12
*.pfx
*.crt
*.cert
*.jks
*.keystore
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
*.mobileprovision
